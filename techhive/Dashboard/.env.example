# NuxtHub Configuration
# Get your token from https://admin.hub.nuxt.com
NUXT_HUB_PROJECT_KEY=

# Optional: Override the NuxtHub URL (for self-hosted)
# NUXT_HUB_URL=

# Dashboard app base path. Use /dashboard when reverse-proxying behind the main domain.
NUXT_APP_BASE_URL=/

# Shared TechHive backend API base URL
NUXT_PUBLIC_API_BASE=http://localhost:5000/api/v1

# Dashboard branding
NUXT_PUBLIC_DASHBOARD_NAME=TechHive Dashboard
NUXT_PUBLIC_DASHBOARD_SUBTITLE=Admin and Vendor Console
